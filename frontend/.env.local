# ── Modo de Desenvolvimento ───────────────────────────────────────────────────
# true  → OTP fixo 000000, sem Hunter.io, sem SMTP, social desativado no frontend
# false → comportamento real de produção
NEXT_PUBLIC_DEV_MODE=true

# ── URL pública do backend FastAPI ────────────────────────────────────────────
# Em dev local (sem Docker): http://localhost:8000
# Em Docker (browser do host falando com o backend): http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
