# =============================================================================
# TalentBridge — Variáveis de Ambiente
# =============================================================================
# Como usar:
#   cp .env.example .env
#   Edite o .env com seus dados e rode o comando do modo escolhido abaixo.
# =============================================================================

# ── Modo do Banco de Dados ────────────────────────────────────────────────────
#
#   MODO DOCKER (padrão) — MySQL sobe junto com o projeto no Docker:
#     DB_HOST=db
#     Rodar com: docker-compose --profile docker-db up --build
#     Conectar no Workbench: 127.0.0.1 : 3307
#
#   MODO LOCAL — usa o MySQL instalado na sua máquina:
#     DB_HOST=host.docker.internal
#     Rodar com: docker-compose up --build
#     Conectar no Workbench: 127.0.0.1 : 3306 (normal)
#
# Troque apenas o DB_HOST abaixo para alternar entre os modos.

# ── Banco de Dados ────────────────────────────────────────────────────────────
DB_HOST=db
DB_USER=root
DB_PASSWORD=1234
DB_NAME=talentbridge
DB_PORT=3306

# ── IA / Gemini ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=sua_chave_gemini_aqui

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=substitua_por_uma_string_aleatoria_longa_e_segura
JWT_EXPIRE_MINUTES=60

# ── Hunter.io (validação de e-mails) ─────────────────────────────────────────
HUNTER_API_KEY=sua_chave_hunter_aqui

# ── E-mail / SMTP (Gmail) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_app_aqui
EMAIL_FROM=TalentBridge <seuemail@gmail.com>

# ── Login Social — Google ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=seu_client_id_google
GOOGLE_CLIENT_SECRET=seu_client_secret_google
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/social/google/callback

# ── Login Social — LinkedIn ───────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=seu_client_id_linkedin
LINKEDIN_CLIENT_SECRET=seu_client_secret_linkedin
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/social/linkedin/callback

# ── URL do Frontend ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend (build Next.js) ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# false → comportamento real de produção
NEXT_PUBLIC_DEV_MODE=true

# ── Modo de Desenvolvimento ───────────────────────────────────────────────────
# true  → OTP fixo 000000, sem Hunter.io, sem SMTP, social desativado
# false → comportamento real de produção
DEV_MODE=true