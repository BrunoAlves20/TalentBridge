# ── Banco de Dados ────────────────────────────────────────────────────────────
DB_HOST=host.docker.internal
DB_USER=seu_usuario_mysql
DB_PASSWORD=sua_senha_mysql
DB_NAME=talentbridge
DB_PORT=3306

# ── IA / Gemini ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=sua_chave_gemini_aqui

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# Gere uma string aleatória longa, ex: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=substitua_por_uma_string_aleatoria_longa_e_segura
JWT_EXPIRE_MINUTES=60

# ── Hunter.io (validação de e-mails) ─────────────────────────────────────────
HUNTER_API_KEY=sua_chave_hunter_aqui

# ── E-mail / SMTP (Gmail) ─────────────────────────────────────────────────────
# Para Gmail, gere uma "Senha de App" (não use sua senha normal):
# Acesse: https://myaccount.google.com/apppasswords
# Requisito: autenticação de 2 fatores ativada na conta Google.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_app_aqui
EMAIL_FROM=TalentBridge <seuemail@gmail.com>

# ── Login Social — Google ─────────────────────────────────────────────────────
# Crie em: https://console.cloud.google.com/
# Escopos: openid, profile, email
# Redirect URI autorizada: http://localhost:8000/auth/social/google/callback
GOOGLE_CLIENT_ID=seu_client_id_google
GOOGLE_CLIENT_SECRET=seu_client_secret_google
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/social/google/callback

# ── Login Social — LinkedIn ───────────────────────────────────────────────────
# Crie em: https://www.linkedin.com/developers/
# Produto: "Sign In with LinkedIn using OpenID Connect"
# Escopos: openid, profile, email
# Redirect URI autorizada: http://localhost:8000/auth/social/linkedin/callback
LINKEDIN_CLIENT_ID=seu_client_id_linkedin
LINKEDIN_CLIENT_SECRET=seu_client_secret_linkedin
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/social/linkedin/callback

# ── URL do Frontend ───────────────────────────────────────────────────────────
# Usada pelo backend para redirecionar após o callback OAuth
FRONTEND_URL=http://localhost:3000